# =============================================================================
# Customer Delivery Analytics（PySide6 / PyInstaller / Windows 業務PC 想定）
# =============================================================================

# --- Python 実行時・キャッシュ ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# --- パッケージング（setuptools 等）---
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/

# --- PyInstaller（build_exe.ps1）---
# dist/・build/ に exe 一式が出力される。.spec はコマンドライン実行で都度生成されがちなため除外。
build/
dist/
*.spec

# --- 仮想環境 ---
.venv/
venv/
ENV/
env/

# --- 環境変数・ローカル秘密（コミット禁止）---
.env
.env.*
!.env.example

# --- テスト・カバレッジ ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# --- 型チェック・リンター ---
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# --- IDE / エディタ ---
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.swp
*.swo
*~

# --- OS（Windows 中心）---
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store

# --- ログ・一時ファイル ---
*.log
*.tmp
*.temp
*.bak

# --- Excel：エクスポート・一時保存の誤コミット防止 ---
# Office が開いている間に作られるロックファイル（~$ で始まる）
~$*.xlsx
tmp_*.xlsx
# 必要なら *.xlsx も有効化（テンプレート等をリポジトリ管理する場合はコメントアウト）
# *.xlsx
